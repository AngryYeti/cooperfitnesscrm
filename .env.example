# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Zoho SMTP — host depends on account type
#   Personal/free:    smtp.zoho.com
#   Workplace/org:    smtp.zohocloud.<region>  (e.g. smtp.zohocloud.ca, .eu, .in, .com.au)
# Check Zoho Settings -> Mail -> POP/IMAP for the exact outgoing host.
ZOHO_SMTP_HOST=smtp.zohocloud.ca
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=
EMAIL_FROM="Cooper Fitness <noreply@cooper.fitness>"

# Reply-to address for outgoing emails
EMAIL_REPLY_TO=evan@cooper.fitness

# Webhooks
WEBHOOK_SECRET=

# Cron
CRON_SECRET=

# DocuSeal (https://docuseal.co)
DOCUSEAL_API_TOKEN=
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_WEBHOOK_SECRET=

# Vercel deployment URL (used for intake links)
VERCEL_DOMAIN=

# Timezone for calendar scheduling and daily digests (IANA timezone, e.g. America/New_York)
TIMEZONE=America/New_York
